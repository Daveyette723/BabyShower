<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Baby In Bloom - Daveyette & Akil's Baby Shower</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..700;1,400..700&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        :root { --pink: #FADADD; --yellow: #FEF6C9; --lavender: #E6E6FA; --sage: #D1E2D3; --cream: #FFFDD0; --gold: #D4AF37; --text-dark: #4A4A4A; --white-alpha: rgba(255, 255, 255, 0.85); }
        * { box-sizing: border-box; margin: 0; padding: 0; scroll-behavior: smooth; }
        body { font-family: 'Montserrat', sans-serif; color: var(--text-dark); background: linear-gradient(135deg, var(--cream), var(--pink), var(--lavender), var(--sage)); background-size: 400% 400%; animation: gradientBG 20s ease infinite; overflow-x: hidden; position: relative; }
        @keyframes gradientBG { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }
        h1, h2, h3 { font-family: 'Playfair Display', serif; font-weight: 600; color: #5C4033; text-align: center; }
        #animation-container { position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 10; }
        .container { max-width: 800px; margin: 0 auto; padding: 20px; }
        section { background: var(--white-alpha); border-radius: 24px; padding: 40px 30px; margin: 40px auto; box-shadow: 0 10px 30px rgba(163, 125, 125, 0.15); border: 2px solid rgba(212, 175, 55, 0.2); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); text-align: center; position: relative; z-index: 2; }
        .gold-divider { height: 2px; background: linear-gradient(to right, transparent, var(--gold), transparent); margin: 20px auto; width: 60%; }
        .hero { padding: 60px 20px; background: rgba(255, 255, 255, 0.7); border-radius: 0 0 50px 50px; margin-top: 0; }
        .hero h1 { font-size: 2.8rem; letter-spacing: 2px; color: #6E473B; margin-bottom: 10px; }
        .hero .subtitle { font-size: 1.4rem; font-style: italic; margin: 15px 0; color: #8A624A; }
        .hero .tagline { font-size: 1.1rem; line-height: 1.6; max-width: 600px; margin: 20px auto; }
        .countdown-container { display: flex; justify-content: center; gap: 15px; margin-top: 30px; }
        .countdown-box { background: white; padding: 15px; border-radius: 15px; min-width: 70px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); border: 1px solid var(--pink); }
        .countdown-box span { display: block; font-size: 1.8rem; font-weight: 600; color: var(--gold); font-family: 'Playfair Display', serif; }
        .countdown-box label { font-size: 0.75rem; text-transform: uppercase; color: #777; }
        .btn { display: inline-block; background: linear-gradient(135deg, #FFF0F5, #FADADD); color: #5C4033; padding: 15px 35px; border-radius: 30px; text-decoration: none; font-weight: 600; font-size: 1.1rem; border: 2px solid var(--gold); box-shadow: 0 5px 15px rgba(212, 175, 55, 0.2); margin-top: 15px; cursor: pointer; }
        .btn-large { font-size: 1.3rem; padding: 18px 45px; }
        .map-container { border-radius: 15px; overflow: hidden; border: 2px solid var(--sage); margin-top: 20px; }
        .map-container iframe { width: 100%; height: 250px; border: 0; }
        .rsvp-contacts { display: flex; justify-content: space-around; flex-wrap: wrap; gap: 20px; margin: 25px 0; }
        .contact-card { background: white; padding: 20px; border-radius: 15px; width: 45%; min-width: 240px; border: 1px solid var(--lavender); }
        .contact-card a { color: #8A624A; text-decoration: none; font-weight: 500; font-size: 1.1rem; }
        .deadline { font-weight: 600; color: #C08081; font-size: 1.1rem; }
        .form-group { margin-bottom: 15px; text-align: left; }
        label { display: block; margin-bottom: 5px; font-weight: 500; }
        input, textarea, select { width: 100%; padding: 12px; border: 1px solid #DDD; border-radius: 10px; font-family: 'Montserrat', sans-serif; }
        .gallery-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-top: 25px; }
        .gallery-item { position: relative; border-radius: 15px; overflow: hidden; aspect-ratio: 1 / 1; border: 3px solid white; box-shadow: 0 4px 10px rgba(0,0,0,0.08); background: var(--pink); display: flex; align-items: center; justify-content: center; }
        .gallery-item-1 { background: url('https://images.unsplash.com/photo-1551854838-212c50b4c184?auto=format&fit=crop&w=500&q=80') center/cover; }
        .gallery-item-2 { background: url('https://images.unsplash.com/photo-1519689680058-324335c77eba?auto=format&fit=crop&w=500&q=80') center/cover; }
        .gallery-item-3 { background: url('https://images.unsplash.com/photo-1542038784456-1ea8e935640e?auto=format&fit=crop&w=500&q=80') center/cover; }
        .gallery-label { position: absolute; bottom: 0; width: 100%; background: rgba(255,255,255,0.85); padding: 8px; font-size: 0.85rem; text-align: center; }
        footer { text-align: center; padding: 60px 20px; background: rgba(255, 255, 255, 0.8); margin-top: 60px; border-radius: 50px 50px 0 0; }
        .success-msg { color: #4F7942; font-weight: 500; margin-top: 10px; display: none; }
        @media (max-width: 600px) { .hero h1 { font-size: 2.2rem; } section { padding: 30px 15px; } .contact-card { width: 100%; } }
    </style>
</head>
<body>
    <div id="animation-container"></div>
    <div class="container">
        <section class="hero">
            <h1>🌸 BABY IN BLOOM 🌸</h1>
            <div class="gold-divider"></div>
            <p class="subtitle">A Baby Shower Honoring Daveyette & Akil</p>
            <p class="tagline">🦋 A little wildflower is on the way.<br><br>Join us as we celebrate the upcoming arrival of our sweet baby girl with an afternoon filled with flowers, butterflies, treats, and love.</p>
            <div class="countdown-container">
                <div class="countdown-box"><span id="days">00</span><label>Days</label></div>
                <div class="countdown-box"><span id="hours">00</span><label>Hrs</label></div>
                <div class="countdown-box"><span id="minutes">00</span><label>Mins</label></div>
                <div class="countdown-box"><span id="seconds">00</span><label>Secs</label></div>
            </div>
        </section>

        <section id="details">
            <h2>📅 Event Details</h2>
            <div class="gold-divider"></div>
            <p style="font-size: 1.2rem; font-weight: 600; margin-bottom: 8px;">July 8, 2026</p>
            <p style="font-size: 1.1rem; color: #666; margin-bottom: 15px;">3:00 PM – 5:00 PM</p>
            <p style="font-weight: 500;">Cheddar’s Scratch Kitchen</p>
            <p style="color: #666; margin-bottom: 15px;">21001 Gulf Fwy<br>Webster, TX 77598</p>
            <div class="map-container">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3471.2185566374826!2d-95.12790932378822!3d29.539151542385157!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x86409fa4966687a7%3A0xe9f75ec5883ef073!2sCheddar&#39;s%20Scratch%20Kitchen!5e0!3m2!1sen!2sus!4v1710000000000!5m2!1sen!2sus" width="100%" height="250" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
            </div>
            <a href="https://maps.google.com/?q=Cheddar’s+Scratch+Kitchen+21001+Gulf+Fwy+Webster+TX+77598" target="_blank" class="btn">📍 Open in Maps</a>
        </section>

        <section id="rsvp">
            <h2>💌 RSVP Details</h2>
            <div class="gold-divider"></div>
            <div class="rsvp-contacts">
                <div class="contact-card"><h3>Daveyette</h3><a href="tel:832-438-0306">📞 832-438-0306</a></div>
                <div class="contact-card"><h3>Akil</h3><a href="tel:409-877-9410">📞 409-877-9410</a></div>
            </div>
            <p class="deadline">Please RSVP by June 30, 2026</p>
        </section>

        <section id="registry">
            <h2>🎁 Registry</h2>
            <div class="gold-divider"></div>
            <a href="https://www.amazon.com/baby-reg/daveyette-chambers-june-2026-houston/7D2KD3BB60WP" target="_blank" class="btn btn-large">🌸 View Baby Registry 🌸</a>
        </section>

        <section id="diaper-raffle">
            <h2>🎀 Diaper Raffle 🎀</h2>
            <div class="gold-divider"></div>
            <p>Bring a pack of diapers (any size) and receive an entry into our diaper raffle.</p>
            <p style="font-weight: 600; color: #8A624A; margin-top: 10px;">The more packs you bring, the more chances you have to win.</p>
        </section>

        <section id="food">
            <h2>🍰 Food & Treats</h2>
            <div class="gold-divider"></div>
            <p>Guests are welcome to order from the menu at their own expense.</p>
            <p style="font-weight: 500; margin-top: 10px;">Desserts, sweets, and special treats will be provided.</p>
        </section>

        <section id="predictions">
            <h2>✨ Baby Predictions ✨</h2>
            <div class="gold-divider"></div>
            <form onsubmit="event.preventDefault(); document.getElementById('p-sec').style.display='block';">
                <div class="form-group"><label>Birth Date Guess:</label><input type="date" required></div>
                <div class="form-group"><label>Birth Weight Guess:</label><input type="text" placeholder="e.g. 7lbs 4oz" required></div>
                <div class="form-group"><label>Birth Length Guess:</label><input type="text" placeholder="e.g. 20 inches" required></div>
                <button type="submit" class="btn">Submit Guess 🦋</button>
                <p id="p-sec" class="success-msg">Guess submitted! ✨</p>
            </form>
        </section>

        <section id="gallery">
            <h2>📸 Photo Gallery</h2>
            <div class="gold-divider"></div>
            <div class="gallery-grid">
                <div class="gallery-item gallery-item-1"><div class="gallery-label">Maternity</div></div>
                <div class="gallery-item gallery-item-2"><div class="gallery-label">Ultrasound</div></div>
                <div class="gallery-item gallery-item-3"><div class="gallery-label">Family</div></div>
            </div>
        </section>
    </div>

    <footer>
        <h2>With Love,</h2>
        <p style="font-size: 1.4rem; font-family: 'Playfair Display', serif; font-weight: bold; color: #5C4033; margin-bottom: 15px;">Daveyette, Akil & Baby Girl</p>
        <p>🌸🦋 Our Little Wildflower Is Almost Here 🦋🌸</p>
    </footer>

    <script>
        const targetDate = new Date("July 8, 2026 15:00:00").getTime();
        function updateCountdown() {
            const difference = targetDate - new Date().getTime();
            if (difference < 0) return;
            document.getElementById("days").innerText = Math.floor(difference / (1000 * 60 * 60 * 24));
            document.getElementById("hours").innerText = Math.floor((difference % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            document.getElementById("minutes").innerText = Math.floor((difference % (1000 * 60 * 60)) / (1000 * 60));
            document.getElementById("seconds").innerText = Math.floor((difference % (1000 * 60)) / 1000);
        }
        setInterval(updateCountdown, 1000);
        
        const container = document.getElementById('animation-container');
        const items = ['🦋', '🌸', '✨', '🍃'];
        setInterval(() => {
            if (container.childElementCount > 20) return;
            const el = document.createElement('div');
            el.innerText = items[Math.floor(Math.random() * items.length)];
            const startX = Math.random() * window.innerWidth;
            el.style.cssText = `position: absolute; bottom: -50px; left: ${startX}px; font-size: ${Math.random() * 10 + 16}px; opacity: 0.7; transition: transform 10s linear, opacity 10s;`;
            container.appendChild(el);
            setTimeout(() => {
                el.style.transform = `translate(${Math.random() * 100 - 50}px, -${window.innerHeight + 100}px) rotate(360deg)`;
                el.style.opacity = '0';
            }, 100);
            setTimeout(() => el.remove(), 10000);
        }, 1000);
    </script>
</body>
</html>
